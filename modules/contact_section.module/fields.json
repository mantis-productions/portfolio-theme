      "url": { "href": "https://linkedin.com", "type": "EXTERNAL" },
      "open_in_new_tab": true,
      "no_follow": false
    }
  },
  {
    "id": "contact_social_github",
    "name": "github_url",
    "label": "GitHub URL",
    "type": "link",
    "default": {
      "url": { "href": "https://github.com", "type": "EXTERNAL" },
      "open_in_new_tab": true,
      "no_follow": false
    }
  },
  {
