      { "item": "HubSpot Theme Development" },
      { "item": "HubSpot CMS Migration & Optimization" },
      { "item": "Custom Module & Template Creation" },
      { "item": "API Integrations & Automation" },
      { "item": "Technical Consulting & Strategy" }
    ]
  },
  {
    "id": "contact_form_heading",
    "name": "form_heading",
    "label": "Form Card Heading",
    "type": "text",
    "default": "Send Me a Message"
  },
  {
    "id": "contact_portal_id",
    "name": "portal_id",
    "label": "HubSpot Portal ID",
    "type": "text",
    "default": "YOUR_PORTAL_ID"
  },
  {
    "id": "contact_form_id",
    "name": "form_id",
    "label": "HubSpot Form GUID",
    "type": "text",
    "default": "YOUR_FORM_GUID"
  },
  {
    "id": "contact_form_submit_label",
